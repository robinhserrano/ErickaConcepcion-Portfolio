---
import Layout from '../layouts/Layout.astro';
import { Image } from 'astro:assets';

// Import optimized landing page cover images
import ermesPreview from '../assets/Ermes Preview.png';
import gogorillaPreview from '../assets/GoGorilla Preview.png';
import hyphensPreview from '../assets/Hyphens Preview.png';
import mimsPreview from '../assets/MIMS preview.png';
import neutrogenaPreview from '../assets/Neutrogena Preview.png';
import gskPreview from '../assets/GSK.png';
import amazonPreview from '../assets/Amazon.png';
import mimsArCover from '../assets/mims_ar_cover.png';
import mimsBannerCover from '../assets/mims_banner_cover.jpg';
---

<Layout title="ERICKA CN">
    <div class="hidden fixed inset-0 z-[100] items-center justify-center p-4 md:p-8 bg-black/80 backdrop-blur-sm"
        id="project-modal">
        <!-- MODAL CONTAINER (Expanded width) -->
        <div
            class="w-full max-w-[90rem] aspect-auto md:aspect-[16/9] max-h-[95vh] bg-[#0f141a]/95 backdrop-blur-xl border border-primary/30 relative flex flex-col md:flex-row overflow-hidden shadow-[0_0_100px_rgba(20,184,184,0.15)] animate-[decrypt_0.8s_steps(10)_forwards]">

            <div class="absolute top-4 right-4 z-50 bg-[#0f141a] rounded-full">
                <button class="reticle-close text-primary block hover:scale-110 transition-transform group"
                    id="modal-close-btn" style="">
                    <div
                        class="absolute inset-0 border border-primary/50 rounded-full group-hover:border-primary group-hover:shadow-[0_0_10px_rgba(20,184,184,0.5)] transition-all">
                    </div>
                    <div
