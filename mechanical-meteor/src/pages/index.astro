    <script>
        // Project Modal Logic (No hash usage to prevent scroll-to-top)
        const modal = document.getElementById('project-modal');
        const modalCloseBtn = document.getElementById('modal-close-btn');
        document.querySelectorAll('.project-trigger').forEach(trigger => {
            trigger.addEventListener('click', (e) => {
                e.preventDefault();
                const title = trigger.getAttribute('data-title');
                const img = trigger.getAttribute('data-img');
                const tags = trigger.getAttribute('data-tags').split(',');
                const desc = trigger.getAttribute('data-desc');
                const strategy = trigger.getAttribute('data-strategy');

                document.getElementById('modal-title').innerText = title;

                const assetsContainer = document.getElementById('modal-assets-container');
                assetsContainer.innerHTML = '';

                // Asset Injection Logic
                const video = trigger.getAttribute('data-video');
                const gallery = trigger.getAttribute('data-gallery');
                const videoOrder = trigger.getAttribute('data-video-order') || 'default';

                const hasVideo = video && video.trim().length > 0;
                // 1. Preview Image (always first)
                if (img) {
                    const imgEl = document.createElement('img');
                    imgEl.src = img;
                    imgEl.className = 'w-full object-cover opacity-80 hover:opacity-100 transition-all duration-700 block mb-10 rounded-lg border border-white/5';
                    assetsContainer.appendChild(imgEl);
                }

                // 2. Video (if default order)
                if (video && videoOrder !== 'last') {
                    const videoEl = document.createElement('video');
                    videoEl.src = video;
                    videoEl.controls = true;
                    videoEl.autoplay = true;
                    videoEl.muted = true;
                    videoEl.loop = true;
                    videoEl.playsInline = true;
                    videoEl.className = 'w-full aspect-video object-cover opacity-90 hover:opacity-100 transition-all duration-700 block mb-10 rounded-lg border border-primary/30 shadow-[0_0_15px_rgba(20,184,184,0.1)]';
                    assetsContainer.appendChild(videoEl);
                }

                // 3. Gallery
                if (gallery) {
                    gallery.split(',').forEach(src => {
                        if (src.trim()) {
                            const imgEl = document.createElement('img');
                            imgEl.src = src.trim();
                            imgEl.className = 'w-full object-cover opacity-80 hover:opacity-100 transition-all duration-700 block mb-10 rounded-lg border border-white/5';
                            assetsContainer.appendChild(imgEl);
                        }
                    });
                }

                // 4. Video (if last order)
                if (video && videoOrder === 'last') {
                    const videoEl = document.createElement('video');
                    videoEl.src = video;
                    videoEl.controls = true;
                    videoEl.autoplay = true;
                    videoEl.muted = true;
                    videoEl.loop = true;
                    videoEl.playsInline = true;
                    videoEl.className = 'w-full aspect-video object-cover opacity-90 hover:opacity-100 transition-all duration-700 block mt-4 mb-12 rounded-lg border border-primary/30 shadow-[0_0_20px_rgba(20,184,184,0.15)]';
                    assetsContainer.appendChild(videoEl);
                }

                // End Marker
                const endMarker = document.createElement('div');
                endMarker.className = 'h-32 md:h-64 flex items-center justify-center border-t border-primary/10 mt-8';
                endMarker.innerHTML = '<span class="text-[10px] text-primary/30 tracking-[0.5em] uppercase">END_OF_MANIFEST</span>';
                assetsContainer.appendChild(endMarker);

                // Reset and handle scroll indicator
                const scrollContainer = document.getElementById('modal-scroll-container');
                const scrollIndicator = document.getElementById('modal-scroll-indicator');
                if (scrollContainer && scrollIndicator) {
                    scrollContainer.scrollTop = 0;
                    scrollIndicator.style.opacity = '1';

                    scrollContainer.onscroll = () => {
                        const isAtBottom = scrollContainer.scrollHeight - scrollContainer.scrollTop <= scrollContainer.clientHeight + 50;
                        scrollIndicator.style.opacity = isAtBottom ? '0' : '1';
                    };
                }

                document.getElementById('modal-desc').innerText = desc;
                const execution = trigger.getAttribute('data-execution');
                const strategyEl = document.getElementById('modal-strategy');
                if (strategyEl) {
                    let combinedMethodology = strategy || '';
                    if (execution) {
                        combinedMethodology += (combinedMethodology ? '\n\n' : '') + execution;
                    }
                    strategyEl.innerText = combinedMethodology || 'Methodology pending formulation.';
                }

                const challenge = trigger.getAttribute('data-challenge');
                const challengeEl = document.getElementById('modal-challenge');
                if (challengeEl) challengeEl.innerText = challenge || '';

                const outcome = trigger.getAttribute('data-outcome');
                const outcomeEl = document.getElementById('modal-outcome');
                if (outcomeEl) outcomeEl.innerText = outcome || '';

                const link = trigger.getAttribute('data-link');
                const ctaLink = document.getElementById('modal-cta-link');
                if (ctaLink) {
                    ctaLink.href = link || '#';
                    ctaLink.style.display = link ? 'inline-block' : 'none';
                }
                const tagsContainer = document.getElementById('modal-tags');
                tagsContainer.innerHTML = '';
                tags.forEach(tag => {
                    const span = document.createElement('span');
                    span.className = 'px-3 py-1 bg-white/5 border border-white/10 rounded-none text-xs text-gray-300';
                    span.innerText = tag.trim();
                    tagsContainer.appendChild(span);
                });
                modal.classList.remove('hidden');
                modal.classList.add('flex', 'active');
                document.body.classList.add('modal-open');
            });
        });
        modalCloseBtn.addEventListener('click', () => {
            modal.classList.add('hidden');
            modal.classList.remove('flex', 'active');
            document.body.classList.remove('modal-open');
        });
        // Close modal if clicking outside the glass panel
        modal.addEventListener('click', (e) => {
            if (e.target === modal) {
                modal.classList.add('hidden');
                modal.classList.remove('flex', 'active');
                document.body.classList.remove('modal-open');
            }
        });
        // Mobile Menu Logic
        const menuToggle = document.getElementById('menu-toggle');
        const mobileMenu = document.getElementById('mobile-menu');
        const mobileLinks = mobileMenu.querySelectorAll('a');
        const toggleMenu = () => {
            const isOpen = mobileMenu.classList.contains('active');
            if (isOpen) {
                mobileMenu.classList.remove('active');
                document.body.classList.remove('menu-open');
            } else {
                mobileMenu.classList.add('active');
                document.body.classList.add('menu-open');
            }
        };
        menuToggle.addEventListener('click', toggleMenu);
        mobileLinks.forEach(link => {
            link.addEventListener('click', () => {
                mobileMenu.classList.remove('active');
                document.body.classList.remove('menu-open');
            });
        });
        // Kinetic Header Typing Animation Logic
        const initTypewriter = () => {
            const headers = document.querySelectorAll('.typewriter-target');
            const typeEffect = (element) => {
                if (element.dataset.typed === 'true') return;
                element.dataset.typed = 'true';
                const originalText = element.innerText;
                element.innerText = '';
                const cursor = document.createElement('span');
                cursor.className = 'typewriter-cursor';
                element.appendChild(cursor);
                let charIndex = 0;
                const typeSpeed = 50;
                const typeChar = () => {
                    if (charIndex < originalText.length) {
                        const charSpan = document.createElement('span');
                        charSpan.className = 'char-reveal';

                        // Handle spacing: if the character is a space, use &nbsp;
                        const currentChar = originalText[charIndex];
                        if (currentChar === ' ') {
                            charSpan.innerHTML = '&nbsp;';
                        } else {
                            charSpan.textContent = currentChar;
                        }

                        element.insertBefore(charSpan, cursor);

                        setTimeout(() => {
                            charSpan.classList.add('active');
                        }, 50);

                        charIndex++;
                        setTimeout(typeChar, typeSpeed + (Math.random() * 40));
                    } else {
                        setTimeout(() => {
                            cursor.style.display = 'none';
                        }, 800);
                    }
                };


                typeChar();
            };
            const observerOptions = {
                root: null,
                threshold: 0.2,
                rootMargin: '0px'
            };
            const observer = new IntersectionObserver((entries) => {
                entries.forEach(entry => {
                    if (entry.isIntersecting) {
                        typeEffect(entry.target);
                    }
                });
            }, observerOptions);
            headers.forEach(header => observer.observe(header));
        };
        document.addEventListener('DOMContentLoaded', initTypewriter);
    </script>
    <script>
        document.addEventListener('DOMContentLoaded', () => {
            const filterButtons = document.querySelectorAll('.filter-btn');
            const projectCards = document.querySelectorAll('.project-trigger');

            filterButtons.forEach(btn => {
                btn.addEventListener('click', () => {
                    const filter = btn.getAttribute('data-filter');

                    // Update Active State Visuals
                    filterButtons.forEach(b => {
                        b.classList.remove('border-primary', 'text-primary', 'shadow-[0_4px_10px_-4px_rgba(0,240,255,0.5)]');
                        b.classList.add('border-transparent', 'text-gray-500');
                    });
                    btn.classList.add('border-primary', 'text-primary', 'shadow-[0_4px_10px_-4px_rgba(0,240,255,0.5)]');
                    btn.classList.remove('border-transparent', 'text-gray-500');

                    // Filter Projects
                    projectCards.forEach(card => {
                        const category = card.getAttribute('data-category');

                        // Smooth transition
                        card.style.transition = 'opacity 0.3s ease, transform 0.3s ease';

                        const isHidden = card.getAttribute('data-hidden') === 'true';

                        if (!isHidden && (filter === 'all' || category === filter)) {
                            card.style.display = 'grid';
                            setTimeout(() => {
                                card.style.opacity = '1';
                                card.style.transform = 'translateY(0)';
                            }, 10);
                        } else {
                            card.style.opacity = '0';
                            card.style.transform = 'translateY(20px)';
                            setTimeout(() => {
                                card.style.display = 'none';
                            }, 300);
                        }
                    });
                });
            });

            // Trigger initial filtering state so the default tab applies its limits on load
            const activeFilter = document.querySelector('.filter-btn.border-primary');
            if (activeFilter) {
                activeFilter.click();
            } else if (filterButtons.length > 0) {
                filterButtons[0].click();
            }
        });

        // Theme Toggle Logic
        document.addEventListener('DOMContentLoaded', () => {
            const html = document.documentElement;
            const desktopToggle = document.getElementById('theme-toggle-desktop');
            const desktopIcon = document.getElementById('theme-icon-desktop');
            const mobileToggle = document.getElementById('theme-toggle-mobile');
            const mobileText = document.getElementById('mobile-theme-text');

            // Default is dark
            let isLightMode = false;

            function updateThemeUI() {
                if (isLightMode) {
                    html.classList.remove('dark');
                    html.classList.add('light');
                    if(desktopIcon) desktopIcon.textContent = 'dark_mode';
                    if(mobileText) mobileText.textContent = 'LIGHT';
                } else {
                    html.classList.remove('light');
                    html.classList.add('dark');
                    if(desktopIcon) desktopIcon.textContent = 'light_mode';
                    if(mobileText) mobileText.textContent = 'DARK';
                }
            }

            function toggleTheme() {
                isLightMode = !isLightMode;
                updateThemeUI();
            }

            if (desktopToggle) {
                desktopToggle.addEventListener('click', toggleTheme);
            }
            if (mobileToggle) {
                mobileToggle.addEventListener('click', toggleTheme);
            }
        });
    </script>
</Layout>
