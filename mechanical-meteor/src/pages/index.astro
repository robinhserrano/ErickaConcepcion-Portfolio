                        class="bg-secondary/10 text-secondary text-[10px] px-3 py-1 font-bold tracking-[0.2em] border border-secondary/20">v2.0.26_STABLE</span>
                </div>

                <!-- Content Sections -->
                <div class="space-y-8 overflow-y-auto pr-4 custom-scrollbar max-h-[40vh] md:max-h-none">
                    <section>
                        <h2 class="text-primary font-bold text-xs tracking-[0.3em] mb-3 flex items-center gap-2">
                            <span class="w-1 h-3 bg-primary"></span> [ 01_OBJECTIVE ]
                        </h2>
                        <h3 class="text-white text-3xl md:text-5xl font-black uppercase tracking-tighter glow-text mb-4"
                            id="modal-title">PROJECT_TITLE</h3>
                        <p class="text-gray-300 text-lg md:text-xl font-medium leading-relaxed max-w-xl"
                            id="modal-desc">
                            Project Description goes here.
                        </p>
                    </section>

                    <section>
                        <h2 class="text-accent font-bold text-xs tracking-[0.3em] mb-3 flex items-center gap-2">
                            <span class="w-1 h-3 bg-accent"></span> [ 02_CONSTRAINT ]
                        </h2>
                        <p class="text-gray-400 text-lg leading-relaxed max-w-xl whitespace-pre-line"
                            id="modal-challenge"></p>
                    </section>

                    <section>
                        <h2 class="text-secondary font-bold text-xs tracking-[0.3em] mb-3 flex items-center gap-2">
                            <span class="w-1 h-3 bg-secondary"></span> [ 03_METHODOLOGY ]
                        </h2>
                        <div class="flex flex-wrap gap-2 mb-4" id="modal-tags"><!-- Tags injected here --></div>
                        <p class="text-gray-400 text-lg leading-relaxed max-w-xl mt-4 whitespace-pre-line"
                            id="modal-strategy"></p>
                    </section>

                    <section class="hidden">
                        <h2 class="text-blue-400 font-bold text-xs tracking-[0.3em] mb-3 flex items-center gap-2">
                            <span class="w-1 h-3 bg-blue-400"></span> [ 04_EXECUTION ]
