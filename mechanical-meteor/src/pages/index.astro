            </div>
            <div
                class="absolute bottom-1/4 -right-20 w-[30rem] h-[30rem] bg-secondary/10 blur-[120px] rounded-full pointer-events-none hidden md:block">
            </div>
        </div>
    </div>
    <div class="retro-grid animate-grid-float"></div>
